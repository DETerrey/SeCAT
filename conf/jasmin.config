// ============================================================================
// conf/jasmin.config — JASMIN LOTUS2 site-specific overrides
// ============================================================================
//
// Copy this file to your SeCAT working directory on JASMIN and pass it at
// runtime with -c:
//
//   nextflow run DerbyDT/SeCAT \
//       -profile slurm,singularity \
//       -c conf/jasmin.config \
//       -params-file params.yaml
//
// This file overrides the generic slurm profile with LOTUS2 partition names
// and resource settings. Edit to match your allocation if needed.
// ============================================================================

process {

    // LOTUS2 partition mapping
    // short-serial : <=24h, 1 node, serial jobs
    // long-serial  : <=168h, 1 node, serial jobs
    // par-single   : <=24h, multi-core on 1 node
    // high-mem     : <=48h, nodes with >=256GB RAM

    withLabel: 'mem_4g' {
        queue          = 'short-serial'
        clusterOptions = '--mem=4G --ntasks=1'
    }
    withLabel: 'mem_8g' {
        queue          = 'short-serial'
        clusterOptions = '--mem=8G --ntasks=1'
    }
    withLabel: 'mem_16g' {
        queue          = 'short-serial'
        clusterOptions = '--mem=16G --ntasks=1'
    }
    withLabel: 'mem_16g_cpu4' {
        queue          = 'par-single'
        clusterOptions = '--mem=16G --ntasks=4'
    }
    withLabel: 'mem_18g' {
        queue          = 'short-serial'
        clusterOptions = '--mem=18G --ntasks=1'
    }
    withLabel: 'mem_30g' {
        queue          = 'short-serial'
        clusterOptions = '--mem=30G --ntasks=1'
    }
    withLabel: 'mem_48g_cpu16' {
        queue          = 'par-single'
        clusterOptions = '--mem=48G --ntasks=16'
        time           = '12h'
    }
    withLabel: 'mem_64g' {
        queue          = 'high-mem'
        clusterOptions = '--mem=64G --ntasks=1'
    }
    withLabel: 'mem_64g_cpu4' {
        queue          = 'high-mem'
        clusterOptions = '--mem=64G --ntasks=4'
    }
}

// LOTUS2: slow polling to avoid SSH overload on the login node
executor {
    queueSize       = 200
    pollInterval    = '30 sec'
    submitRateLimit = '10/1min'
}

// If your SILVA reference or data live on a GWS not automounted by Singularity,
// uncomment and edit this line:
// singularity.runOptions = '--bind /gws/nopw/j04/YOUR_GWS:/gws/nopw/j04/YOUR_GWS'
