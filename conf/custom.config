// ============================================================================
// conf/custom.config — Site-specific HPC overrides template
// ============================================================================
//
// Use this template if you are running SeCAT on an HPC system other than
// JASMIN. Fill in your site's partition/queue names and resource limits,
// then pass this file at runtime with -c:
//
//   nextflow run DerbyDT/SeCAT \
//       -profile slurm,singularity \
//       -c conf/custom.config \
//       -params-file params.yaml
//
// Only override the labels that differ from the defaults in nextflow.config.
// You do not need to specify all labels — unlisted ones use the defaults.
// ============================================================================

process {

    // ── Required: set your default queue/partition ───────────────────────────
    queue = 'YOUR_DEFAULT_QUEUE'   // e.g. 'compute', 'batch', 'normal'

    // ── Optional: per-label overrides ────────────────────────────────────────
    // Uncomment and edit any labels where your site has specific requirements.
    // Common reasons to override: different partition for high-memory jobs,
    // account/project billing flags, local scratch directives.

    // withLabel: 'mem_64g' {
    //     queue          = 'highmem'
    //     clusterOptions = '--mem=64G --ntasks=1 --account=YOUR_PROJECT'
    // }

    // withLabel: 'mem_64g_cpu4' {
    //     queue          = 'highmem'
    //     clusterOptions = '--mem=64G --ntasks=4 --account=YOUR_PROJECT'
    // }

    // withLabel: 'mem_48g_cpu16' {
    //     queue          = 'parallel'
    //     clusterOptions = '--mem=48G --ntasks=16 --account=YOUR_PROJECT'
    //     time           = '12h'
    // }
}

// ── Optional: executor tuning ────────────────────────────────────────────────
// Adjust if your scheduler is sensitive to rapid job submission:
// executor {
//     queueSize       = 100
//     pollInterval    = '30 sec'
//     submitRateLimit = '20/1min'
// }

// ── Optional: Singularity bind paths ─────────────────────────────────────────
// If your data lives on a filesystem not automounted inside the container:
// singularity.runOptions = '--bind /path/to/your/data:/path/to/your/data'
