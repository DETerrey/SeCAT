// ============================================================================
// conf/custom.config — Site-specific HPC configuration template
// ============================================================================
//
// SeCAT uses generic resource labels (mem_4g, mem_16g, mem_64g etc.) that
// describe what each process NEEDS. This file maps those labels to your
// institution's actual queue/partition names and submission flags.
//
// HOW TO USE:
//   1. Copy this file and fill in your site's settings
//   2. Pass it at runtime with -c:
//
//      nextflow run DerbyDT/SeCAT \
//          -profile slurm,singularity \
//          -c conf/custom.config \
//          -params-file params.yaml
//
// DO I NEED THIS FILE?
//   - SLURM with a single default queue: set just the queue name below
//   - SLURM with multiple partitions (e.g. highmem for large jobs): set per-label overrides
//   - SGE: use -profile sge,singularity (no custom config usually needed)
//   - JASMIN LOTUS2: use -c conf/jasmin.config instead of this file
//
// WHAT IF I DON'T PROVIDE THIS FILE?
//   The generic slurm profile submits jobs without a queue flag, which works
//   on clusters with a single default queue. If your cluster requires a queue
//   name, jobs will be rejected by the scheduler.
//
// RESOURCE LABELS USED BY SECAT:
//   mem_4g         —  4GB RAM, 1 CPU,  2h   (small utility processes)
//   mem_8g         —  8GB RAM, 1 CPU,  4h   (primer mapping)
//   mem_16g        — 16GB RAM, 1 CPU,  4h   (simulation workers, trimming)
//   mem_16g_cpu4   — 16GB RAM, 4 CPU,  4h   (report generation)
//   mem_18g        — 18GB RAM, 1 CPU,  8h   (real data analysis)
//   mem_30g        — 30GB RAM, 1 CPU, 12h   (merge datasets)
//   mem_48g_cpu16  — 48GB RAM, 16 CPU, 12h  (validation)
//   mem_64g        — 64GB RAM, 1 CPU, 24h   (aggregation, study mapping)
//   mem_64g_cpu4   — 64GB RAM, 4 CPU, 48h   (study mapping — DECIPHER alignment)
// ============================================================================

process {

    // ── REQUIRED: set your default queue/partition name ───────────────────────
    queue = 'YOUR_DEFAULT_QUEUE'
    // Examples: 'compute', 'batch', 'normal', 'short', 'all.q'

    // ── OPTIONAL: override specific labels for high-memory or parallel jobs ───
    // Most clusters need this only for mem_64g and mem_64g_cpu4 if those
    // require a different partition (e.g. 'highmem').
    // Remove the // to uncomment lines you need.

    // withLabel: 'mem_64g' {
    //     queue          = 'highmem'
    //     clusterOptions = '--mem=64G --ntasks=1'
    // }

    // withLabel: 'mem_64g_cpu4' {
    //     queue          = 'highmem'
    //     clusterOptions = '--mem=64G --ntasks=4'
    // }

    // withLabel: 'mem_48g_cpu16' {
    //     queue          = 'parallel'
    //     clusterOptions = '--mem=48G --ntasks=16'
    //     time           = '12h'
    // }

    // ── OPTIONAL: add account/project billing flag to all jobs ────────────────
    // clusterOptions = '--account=YOUR_PROJECT_CODE'
}

// ── OPTIONAL: Singularity bind paths ──────────────────────────────────────────
// If your data (manifest files, SILVA reference, study FASTAs) lives on a
// filesystem that is not automatically mounted inside the Singularity container,
// add bind mounts here. Common on systems with dedicated storage volumes.
//
// singularity.runOptions = '--bind /path/to/your/data:/path/to/your/data'
//
// Example — if data is at /scratch/projects/myproject/:
// singularity.runOptions = '--bind /scratch/projects/myproject:/scratch/projects/myproject'

// ── OPTIONAL: scheduler tuning ────────────────────────────────────────────────
// If your cluster is sensitive to rapid job submission, reduce the rate:
// executor {
//     queueSize       = 100
//     pollInterval    = '30 sec'
//     submitRateLimit = '20/1min'
// }

